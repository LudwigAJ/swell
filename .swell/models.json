{
  "models": {
    "claude": {
      "provider": "anthropic",
      "default_model": "claude-sonnet-4-20250514",
      "models": {
        "sonnet": "claude-sonnet-4-20250514",
        "opus": "claude-opus-4-20250514",
        "haiku": "claude-haiku-4-20250730"
      },
      "routing": {
        "planning": "opus",
        "coding": "sonnet",
        "fast_tasks": "haiku",
        "review": "opus"
      },
      "fallback_chain": ["claude-sonnet-4-20250514", "gpt-4o", "claude-haiku-4-20250730"]
    },
    "openai": {
      "provider": "openai",
      "default_model": "gpt-4o",
      "models": {
        "gpt-4o": "gpt-4o",
        "gpt-4o-mini": "gpt-4o-mini"
      },
      "fallback_chain": ["gpt-4o", "gpt-4o-mini"]
    }
  },
  "cost_optimization": {
    "prompt_caching": true,
    "semantic_caching": true,
    "batch_operations": true
  }
